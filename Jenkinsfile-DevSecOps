pipeline {
    agent any

    environment {
        SONAR_TOKEN = credentials('sonar-token')
        SNYK_TOKEN  = credentials('snyk-token')
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/rootpromptnext/java-spring-boot-app1.git'
            }
        }

        stage('Build (Maven)') {
            steps {
                sh 'mvn clean verify'
            }
        }

        stage('Snyk Test (SCA)') {
            steps {
                sh '''
                docker run --rm \
                  -e SNYK_TOKEN=$SNYK_TOKEN \
                  -v "$PWD":/project \
                  -w /project \
                  snyk/snyk:maven \
                  snyk test --severity-threshold=high || true
                '''
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh '''
                docker run --rm \
                  -v "$PWD":/project \
                  -w /project \
                  aquasec/trivy:latest fs \
                  --severity HIGH,CRITICAL \
                  --format json \
                  -o trivy-report.json \
                  . || true
                '''
            }
        }

        stage('SonarCloud Analysis') {
            steps {
                sh '''
                docker run --rm \
                  -v "$PWD":/usr/src \
                  -w /usr/src \
                  sonarsource/sonar-scanner-cli:5.0.1 \
                  sonar-scanner \
                    -Dsonar.projectKey=java-springboot-app \
                    -Dsonar.organization=rootpromptnext \
                    -Dsonar.host.url=https://sonarcloud.io \
                    -Dsonar.login=$SONAR_TOKEN \
                    -Dsonar.sources=src/main/java \
                    -Dsonar.java.binaries=target/classes
                '''
            }
        }

        stage('DAST - OWASP ZAP Scan') {
            steps {
                sh '''
                docker run --rm \
                  -v "$PWD":/zap/wrk \
                  ghcr.io/zaproxy/zaproxy:stable \
                  zap.sh -cmd \
                  -quickurl https://example.com \
                  -quickout /zap/wrk/zap-report.html
                '''
            }
        }

        stage('Snyk Monitor') {
            steps {
                sh '''
                docker run --rm \
                  -e SNYK_TOKEN=$SNYK_TOKEN \
                  -v "$PWD":/project \
                  -w /project \
                  snyk/snyk:maven \
                  snyk monitor --project-name=java-springboot-app
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: '*.html, *.json, app.log', fingerprint: true
        }
    }
}
